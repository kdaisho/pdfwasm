{
	"name": "pdfwasm",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "concurrently --names web,api --prefix-colors cyan,yellow \"pnpm --filter @pdfwasm/web dev\" \"pnpm --filter @pdfwasm/api dev\"",
		"dev:web": "pnpm --filter @pdfwasm/web dev",
		"dev:api": "pnpm --filter @pdfwasm/api dev",
		"build": "pnpm --filter @pdfwasm/web build",
		"build:api": "pnpm --filter @pdfwasm/api build",
		"preview": "pnpm --filter @pdfwasm/web preview",
		"check": "pnpm --filter @pdfwasm/web check",
		"lint": "pnpm --filter @pdfwasm/web lint",
		"lint:fix": "pnpm --filter @pdfwasm/web lint:fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepare": "husky",
		"db:generate": "pnpm --filter @pdfwasm/api db:generate",
		"db:migrate": "pnpm --filter @pdfwasm/api db:migrate"
	},
	"lint-staged": {
		"apps/web/**/*.{js,ts,svelte}": [
			"pnpm --filter @pdfwasm/web exec eslint --fix",
			"prettier --write"
		],
		"apps/api/**/*.{js,ts}": [
			"prettier --write"
		],
		"*.{json,css,md,html}": [
			"prettier --write"
		]
	},
	"devDependencies": {
		"concurrently": "^9.1.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.0"
	}
}
